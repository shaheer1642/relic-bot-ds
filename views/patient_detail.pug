doctype html
html
  head
    title Patient Detail
    meta(charset="utf-8")
    meta(name="viewport" content="width=device-width, initial-scale=1")
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
    link(rel="stylesheet" href="https://stackpath.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css" integrity="sha384-wvfXpqpZZVQGK6TAh5PVlGOfQNHSoD2xbE+QkPxCAFlNEevoEH3Sl0sibVcOQVnN" crossorigin="anonymous")
    link(rel="stylesheet", href="/stylesheets/style.css")
    <script src="/javascripts/main_panel.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.2/dist/umd/popper.min.js" integrity="sha384-IQsoLXl5PILFhosVNubq5LC7Qb9DXgDA9i+tQ8Zj3iwWAwPtgFTxbJ8NT4GN1R8p" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.min.js" integrity="sha384-cVKIPhGWiC2Al4u+LWgxfKTRIcfu0JTxR+EQDz/bgldoEyl4H0zUF0QKbrJ0EcQF" crossorigin="anonymous"></script>
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
  body.container-fluid
    header
      h2.text-center Patient Detail
      h6.text-left MR Number: #{data.patient.mrno}
      p.p1.text-left Name: #{data.patient.name}
      p.p1.text-left Gender: #{data.patient.gender}
      p.p1.text-left Age: #{data.patient.dob}
      p.p1.text-left Reason of visit: #{data.patient.reason_of_visit}
      p.p1.text-left Registeration Date: #{data.patient.dor}
    div(class="d-flex flex-column")
      div.table-wrapper-scroll-y.my-custom-scrollbar.scrollbar.scrollbar-primary
        table.table.table-striped.table-dark(id="consultationTable")
          caption Consultation Record
          thead
            tr
              th(scope="col") ID
              th(scope="col") Complaint
              th(scope="col") Examination
              th(scope="col") Advice
              th(scope="col") Image
              th(scope="col") Date
              th(scope="col")
          tbody
            if (data.consultations)
              each consultation in data.consultations
                tr(id=`consultation${consultation.consult_id}`)
                  th(scope="row") #{consultation.consult_id}
                  td #{consultation.complaint}
                  td #{consultation.examination}
                  td #{consultation.advice}
                  td #{consultation.image}
                  td #{consultation.doc}
                  td
                    div.btn-toolbar
                      form(method="post" action=`/doctor/panel/view/consultation?patient=${data.patient.mrno}&consultation=${consultation.consult_id}`)
                        button.btn.btn-info(type="submit")
                          i.fa.fa-navicon 
                            span
                      button.btn.btn-info(type="submit" onclick=`editConsultationModal(${data.patient.mrno},${consultation.consult_id})`)
                        i.fa.fa-pencil 
                          span
                      button.btn.btn-danger(type="submit" onclick=`deleteConsultation(${data.patient.mrno},${consultation.consult_id})`)
                        i.fa.fa-trash 
                          span
      form(method="get" action="/doctor/panel/view/consultation/add")
        button.btn.btn-primary.btn-block.w-100(type="button" data-bs-toggle="modal" data-bs-target="#addConsultation")
          i.fa.fa-plus 
            span
      div.row 
        div.col 
          div.table-wrapper-scroll-y.my-custom-scrollbar.scrollbar.scrollbar-primary
            table.table.table-striped.table-dark(id="investigationTable")
              caption Investigation Record
              thead
                tr
                  th(scope="col") ID
                  th(scope="col") Type
                  th(scope="col") Date
                  th(scope="col")
              tbody
                if (data.investigations)
                  each investigation in data.investigations
                    tr(id=`investigation${investigation.invest_id}`)
                      th(scope="row") #{investigation.invest_id}
                      td #{investigation.invest_type}
                      td #{investigation.doi}
                      td
                        div.btn-toolbar
                          form(method="post" action=`/doctor/panel/view/investigation?patient=${data.patient.mrno}&investigation=${investigation.invest_id}`)
                            button.btn.btn-info(type="submit")
                              i.fa.fa-navicon 
                                span
                          button.btn.btn-info(type="submit" onclick=`editInvestigationModal(${data.patient.mrno},${investigation.invest_id})`)
                            i.fa.fa-pencil 
                              span
                          button.btn.btn-danger(type="submit" onclick=`deleteInvestigation(${data.patient.mrno},${investigation.invest_id})`)
                            i.fa.fa-trash 
                              span
          form(method="get" action="/doctor/panel/view/investigation/add")
            button.btn.btn-primary.btn-block.w-100(type="button" data-bs-toggle="modal" data-bs-target="#addInvestigation")
              i.fa.fa-plus 
                span
        div.col
          div.table-wrapper-scroll-y.my-custom-scrollbar.scrollbar.scrollbar-primary
            table.table.table-striped.table-dark(id="surgeryTable")
              caption Surgery Record
              thead
                tr
                  th(scope="col") ID
                  th(scope="col") Type
                  th(scope="col") Surgeon
                  th(scope="col") Date
                  th(scope="col")
              tbody
                if (data.surgeries)
                  each surgery in data.surgeries
                    tr(id=`surgery${surgery.surgery_id}`)
                      th(scope="row") #{surgery.surgery_id}
                      td #{surgery.surgery_type}
                      td #{surgery.surgeon_name}
                      td #{surgery.dos}
                      td
                        div.btn-toolbar
                          form(method="post" action=`/doctor/panel/view/surgery?patient=${data.patient.mrno}&surgery=${surgery.surgery_id}`)
                            button.btn.btn-info(type="submit")
                              i.fa.fa-navicon 
                                span
                          button.btn.btn-info(type="submit" onclick=`editSurgeryModal(${data.patient.mrno},${surgery.surgery_id})`)
                            i.fa.fa-pencil 
                              span
                          button.btn.btn-danger(type="submit" onclick=`deleteSurgery(${data.patient.mrno},${surgery.surgery_id})`)
                            i.fa.fa-trash 
                              span
          form(method="get" action="/doctor/panel/view/surgery/add")
            button.btn.btn-primary.btn-block.w-100(type="button" data-bs-toggle="modal" data-bs-target="#addSurgery")
              i.fa.fa-plus 
                span

  div.modal.fade(id="addConsultation" tabindex="-1" data-bs-backdrop="static" aria-labelledby="addConsultationLabel" aria-hidden="true")
    div.modal-dialog.modal-dialog-centered
      div.modal-content
        div.modal-header
          h5.modal-title(id="addConsultationLabel") New consultation
          button.btn-close(type="button" data-bs-dismiss="modal" aria-label="Close")
        div.modal-body
          form(id="addConsultationForm")
            div.mb-3
              div.row
                label.col-sm-4.col-form-label(for="patientName") Name
                div.col-sm-8
                  input.form-control(type="Text" id="patientName" placeholder="Enter patient's name" name="patientName" required)
            div.mb-3
              div.row
                label.col-sm-4.col-form-label(for="patientGender") Gender
                div.col-sm-8
                  select.form-control(id="patientGender" name="patientGender" required)
                    option(selected disabled) Select
                    option Male
                    option Female
            div.mb-3
              div.row
                label.col-sm-4.col-form-label(for="patientReason") Reason of Visit
                div.col-sm-8
                  select.form-control(id="patientReason" name="patientReason" required)
                    option(selected disabled) Select
                    option  Consultation
                    option Surgery
                    option Investigation
            div.mb-3
              div.row
                label.col-sm-4.col-form-label(for="patientDoB") Date of Birth
                div.col-sm-8
                  div.input-group.date
                    input.form-control(type="date" id="patientDoB" name="patientDoB" value="2000-12-31" required)
                    span.input-group-addon
                    span.fa.fa-time
        div.modal-footer.d-flex.flex-column
          div.btn-toolbar
            button.btn.btn-primary(type="submit" onclick="addConsultation()") Add
            button.btn.btn-danger(type="button" data-bs-dismiss="modal") Close

