doctype html
html
  head
    title Patient Detail
    meta(charset="utf-8")
    meta(name="viewport" content="width=device-width, initial-scale=1")
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
    link(rel="stylesheet" href="https://stackpath.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css" integrity="sha384-wvfXpqpZZVQGK6TAh5PVlGOfQNHSoD2xbE+QkPxCAFlNEevoEH3Sl0sibVcOQVnN" crossorigin="anonymous")
    link(rel="stylesheet", href="/stylesheets/style.css")
    <script src="/javascripts/patient_detail.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.2/dist/umd/popper.min.js" integrity="sha384-IQsoLXl5PILFhosVNubq5LC7Qb9DXgDA9i+tQ8Zj3iwWAwPtgFTxbJ8NT4GN1R8p" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.min.js" integrity="sha384-cVKIPhGWiC2Al4u+LWgxfKTRIcfu0JTxR+EQDz/bgldoEyl4H0zUF0QKbrJ0EcQF" crossorigin="anonymous"></script>
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
  body.container-fluid
    header
      h2.text-center Patient Detail
      h6.text-left MR Number: #{data.patient.mrno}
      p.p1.text-left Name: #{data.patient.name}
      p.p1.text-left Gender: #{data.patient.gender}
      p.p1.text-left Age: #{data.patient.dob}
      p.p1.text-left Reason of visit: #{data.patient.reason_of_visit}
      p.p1.text-left Registeration Date: #{data.patient.dor}
    div(class="d-flex flex-column")
      div.table-wrapper-scroll-y.my-custom-scrollbar.scrollbar.scrollbar-primary
        table.table.table-striped.table-dark(id="consultationTable")
          caption Consultation Record
          thead
            tr
              th(scope="col") ID
              th(scope="col") Complaint
              th(scope="col") Examination
              th(scope="col") Advice
              th(scope="col") Image
              th(scope="col") Date
              th(scope="col")
          tbody
            if (data.consultations)
              each consultation in data.consultations
                tr(id=`consultation${consultation.consult_id}`)
                  th(scope="row") #{consultation.consult_id}
                  td #{consultation.complaint}
                  td #{consultation.examination}
                  td #{consultation.advice}
                  td #{consultation.image}
                  td #{consultation.doc}
                  td
                    div.btn-toolbar
                      button.btn.btn-info(type="button" data-bs-toggle="modal" data-bs-target="#viewConsultation")
                        i.fa.fa-navicon 
                          span
                      button.btn.btn-danger(type="submit" onclick=`deleteConsultation(${data.patient.mrno},${consultation.consult_id})`)
                        i.fa.fa-trash 
                          span
      form(method="get" action="/doctor/panel/view/consultation/add")
        button.btn.btn-primary.btn-block.w-100(type="button" data-bs-toggle="modal" data-bs-target="#addConsultation")
          i.fa.fa-plus 
            span
      div.row 
        div.col 
          div.table-wrapper-scroll-y.my-custom-scrollbar.scrollbar.scrollbar-primary
            table.table.table-striped.table-dark(id="investigationTable")
              caption Investigation Record
              thead
                tr
                  th(scope="col") ID
                  th(scope="col") Type
                  th(scope="col") Date
                  th(scope="col")
              tbody
                if (data.investigations)
                  each investigation in data.investigations
                    tr(id=`investigation${investigation.invest_id}`)
                      th(scope="row") #{investigation.invest_id}
                      td #{investigation.invest_type}
                      td #{investigation.doi}
                      td
                        div.btn-toolbar
                          button.btn.btn-danger(type="submit" onclick=`deleteInvestigation(${data.patient.mrno},${investigation.invest_id})`)
                            i.fa.fa-trash 
                              span
          form(method="get" action="/doctor/panel/view/investigation/add")
            button.btn.btn-primary.btn-block.w-100(type="button" data-bs-toggle="modal" data-bs-target="#addInvestigation")
              i.fa.fa-plus 
                span
        div.col
          div.table-wrapper-scroll-y.my-custom-scrollbar.scrollbar.scrollbar-primary
            table.table.table-striped.table-dark(id="surgeryTable")
              caption Surgery Record
              thead
                tr
                  th(scope="col") ID
                  th(scope="col") Type
                  th(scope="col") Surgeon
                  th(scope="col") Date
                  th(scope="col")
              tbody
                if (data.surgeries)
                  each surgery in data.surgeries
                    tr(id=`surgery${surgery.surgery_id}`)
                      th(scope="row") #{surgery.surgery_id}
                      td #{surgery.surgery_type}
                      td #{surgery.surgeon_name}
                      td #{surgery.dos}
                      td
                        div.btn-toolbar
                          button.btn.btn-danger(type="submit" onclick=`deleteSurgery(${data.patient.mrno},${surgery.surgery_id})`)
                            i.fa.fa-trash 
                              span
          form(method="get" action="/doctor/panel/view/surgery/add")
            button.btn.btn-primary.btn-block.w-100(type="button" data-bs-toggle="modal" data-bs-target="#addSurgery")
              i.fa.fa-plus 
                span

  div.modal.fade(id="addConsultation" tabindex="-1" data-bs-backdrop="static" aria-labelledby="addConsultationLabel" aria-hidden="true")
    div.modal-dialog.modal-dialog-centered
      div.modal-content
        div.modal-header
          h5.modal-title(id="addConsultationLabel") New consultation
          button.btn-close(type="button" data-bs-dismiss="modal" aria-label="Close")
        div.modal-body
          form(id="addConsultationForm")
            div.mb-3
              div.row
                label.col-sm-4.col-form-label(for="complaint") Complaint
                div.col-sm-8
                  input.form-control(type="Text" id="complaint" name="complaint" placeholder="Patient's complaint" required)
            div.mb-3
              div.row
                label.col-sm-4.col-form-label(for="examination") Examination
                div.col-sm-8
                  input.form-control(type="Text" id="examination" name="examination" placeholder="Examination" required)
            div.mb-3
              div.row
                label.col-sm-4.col-form-label(for="advice") Advice
                div.col-sm-8
                  input.form-control(type="Text" id="advice" name="advice" placeholder="Doctor's advice" required)
            div.mb-3
              div.row
                label.col-sm-4.col-form-label(for="image") Report image
                div.col-sm-8
                  input.form-control(type="Text" id="image" name="image" placeholder="Insert report image")
        div.modal-footer.d-flex.flex-column
          div.btn-toolbar
            button.btn.btn-primary(type="submit" onclick=`addConsultation(${data.patient.mrno})`) Add
            button.btn.btn-danger(type="button" data-bs-dismiss="modal") Close

  div.modal.fade(id="viewConsultation" tabindex="-1" data-bs-backdrop="static" aria-labelledby="viewConsultationLabel" aria-hidden="true")
    div.modal-dialog.modal-dialog-consult.modal-dialog-centered
      div.modal-content
        div.modal-header
          h5.modal-title(id="viewConsultationLabel") New consultation
          button.btn-close(type="button" data-bs-dismiss="modal" aria-label="Close")
        div.modal-body
          header
            h2.text-center Consultation Detail
            h6.text-left MR Number: #{data.patient.mrno}
            h6.text-left Consultation ID: #{data.patient.mrno}
            p.p1.text-left Complaint:
            p.p1.text-left Examination:
            p.p1.text-left Advice:
            p.p1.text-left Image:
            p.p1.text-left Date: #{data.patient.dor}
          div.row 
            div.col 
              div.table-wrapper-scroll-y.my-custom-scrollbar.scrollbar.scrollbar-primary
                table.table.table-striped.table-dark(id="investigationTable")
                  caption Treatment Record
                  thead
                    tr
                      th(scope="col") ID
                      th(scope="col") Medicine
                      th(scope="col") Str
                      th(scope="col") Frq
                      th(scope="col") Dur
                      th(scope="col")
                  tbody
                    if (data.treatments)
                      each treatment in data.treatments
                        tr(id=`treatment${treatment.treat_id}`)
                          th(scope="row") #{treatment.treat_id}
                          td #{treatment.med_name}
                          td #{treatment.med_str}
                          td #{treatment.med_frq}
                          td #{treatment.med_dur}
                          td
                            div.btn-toolbar
                              button.btn.btn-danger(type="submit" onclick=`deleteTreatment(${data.patient.mrno},${treatment.treat_id})`)
                                i.fa.fa-trash 
                                  span
              button.btn.btn-primary.btn-block.w-100(type="button" data-bs-toggle="modal" data-bs-target="#addTreatment")
                i.fa.fa-plus 
                  span
            div.col
              div.table-wrapper-scroll-y.my-custom-scrollbar.scrollbar.scrollbar-primary
                table.table.table-striped.table-dark(id="surgeryTable")
                  caption Glasses Prescription
                  thead
                    tr
                      th(scope="col") ID
                      th(scope="col") Type
                      th(scope="col") Str
                      th(scope="col") Frq
                      th(scope="col") Dur
                      th(scope="col")
                  tbody
                    if (data.surgeries)
                      each surgery in data.surgeries
                        tr(id=`surgery${surgery.surgery_id}`)
                          th(scope="row") #{surgery.surgery_id}
                          td #{surgery.surgery_type}
                          td #{surgery.surgeon_name}
                          td #{surgery.dos}
                          td
                            div.btn-toolbar
                              button.btn.btn-danger(type="submit" onclick=`deleteSurgery(${data.patient.mrno},${surgery.surgery_id})`)
                                i.fa.fa-trash 
                                  span
              form(method="get" action="/doctor/panel/view/surgery/add")
                button.btn.btn-primary.btn-block.w-100(type="button" data-bs-toggle="modal" data-bs-target="#addSurgery")
                  i.fa.fa-plus 
                    span
        div.modal-footer.d-flex.flex-column
          div.btn-toolbar
            button.btn.btn-primary(type="submit" onclick=`addConsultation(${data.patient.mrno})`) Add
            button.btn.btn-danger(type="button" data-bs-dismiss="modal") Close

  div.modal.fade(id="addInvestigation" tabindex="-1" data-bs-backdrop="static" aria-labelledby="addInvestigationLabel" aria-hidden="true")
    div.modal-dialog.modal-dialog-centered
      div.modal-content
        div.modal-header
          h5.modal-title(id="addInvestigationLabel") New investigation
          button.btn-close(type="button" data-bs-dismiss="modal" aria-label="Close")
        div.modal-body
          form(id="addInvestigationForm")
            div.mb-3
              div.row
                label.col-sm-4.col-form-label(for="invest_type") Type
                div.col-sm-8
                  select.form-control(id="invest_type" name="invest_type" required)
                    option(selected disabled) Select
                    option Pentacam
                    option Crovis
                    option OCT
                    option Biometry
        div.modal-footer.d-flex.flex-column
          div.btn-toolbar
            button.btn.btn-primary(type="submit" onclick=`addInvestigation(${data.patient.mrno})`) Add
            button.btn.btn-danger(type="button" data-bs-dismiss="modal") Close

  div.modal.fade(id="addSurgery" tabindex="-1" data-bs-backdrop="static" aria-labelledby="addSurgeryLabel" aria-hidden="true")
    div.modal-dialog.modal-dialog-centered
      div.modal-content
        div.modal-header
          h5.modal-title(id="addSurgeryLabel") New surgery
          button.btn-close(type="button" data-bs-dismiss="modal" aria-label="Close")
        div.modal-body
          form(id="addSurgeryForm")
            div.mb-3
              div.row
                label.col-sm-4.col-form-label(for="surgeon_name") Surgeon
                div.col-sm-8
                  input.form-control(type="Text" id="surgeon_name" name="surgeon_name" placeholder="Enter surgeon's name"  required)
            div.mb-3
              div.row
                label.col-sm-4.col-form-label(for="surgery_type") Type
                div.col-sm-8
                  select.form-control(id="surgery_type" name="surgery_type" required) 
                    option(selected disabled) Select
                    option PRK
                    option Femto Lasik
                    option Phaco
                    option CXL
        div.modal-footer.d-flex.flex-column
          div.btn-toolbar
            button.btn.btn-primary(type="submit" onclick=`addSurgery(${data.patient.mrno})`) Add
            button.btn.btn-danger(type="button" data-bs-dismiss="modal") Close

  style.
    p.p1 {
      font-size: 15px
    }
    .my-custom-scrollbar {
      position: relative;
      max-height: 30vh;
      overflow: auto;
    }
    .table-wrapper-scroll-y {
      display: block;
    }
    caption {
      caption-side: top;
      font-size: 30px;
    }
    table {border-collapse:collapse; table-layout:fixed; width:310px;}
    table td {width:100px; word-wrap:break-word;}

    .modal .modal-body { /* Vertical scrollbar if necessary */
        max-height: 480px;
        overflow-y: auto;
    }

    body .modal-dialog-consult { /* Width */
        max-width: 80%;
    }