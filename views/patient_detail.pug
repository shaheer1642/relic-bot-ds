            button.btn.btn-danger(type="button" data-bs-dismiss="modal") Close

  style.
    p.p1 {
      font-size: 15px
    }
    .my-custom-scrollbar {
      position: relative;
      height: 30vh;
      overflow: auto;
    }
    .table-wrapper-scroll-y {
      display: block;
    }
    caption {
      caption-side: top;
      font-size: 30px;
    }
    tfoot {
      position: absolute;
      bottom: 0;
    }